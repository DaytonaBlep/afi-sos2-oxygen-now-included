<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>DepletedAtmosphere</defName>
    <hediffClass>OxygenNowIncluded.Hediff_OxygenEffect</hediffClass>
    <label>depleted atmosphere</label>
    <description>Oxygen levels are below optimal. Consciousness is impaired.</description>
    <initialSeverity>0.5</initialSeverity>
    <stages>
      <li>
        <label>depleted atmosphere</label>
        <minSeverity>0.0</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.1</offset>
          </li>
		  <li>
            <capacity>BloodFiltration</capacity>
            <offset>-0.1</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>EnrichedAtmosphere</defName>
    <hediffClass>OxygenNowIncluded.Hediff_OxygenEffect</hediffClass>
    <label>enriched atmosphere</label>
    <description>Oxygen-rich atmosphere boosts cognitive function and physical performance.</description>
    <initialSeverity>0.5</initialSeverity>
    <stages>
      <li>
        <label>enriched atmosphere</label>
        <minSeverity>0.0</minSeverity>
        <capMods>
          <li>
          <capacity>Consciousness</capacity>
          <offset>0.1</offset>
        </li>
		<li>
          <capacity>BloodFiltration</capacity>
          <offset>0.05</offset>
        </li>
        <li>
          <capacity>Moving</capacity>
          <offset>0.15</offset>
        </li>
        <li>
          <capacity>Manipulation</capacity>
          <offset>0.1</offset>
        </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
</Defs>